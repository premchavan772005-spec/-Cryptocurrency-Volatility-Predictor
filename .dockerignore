# ============================================================
# .dockerignore — Files to exclude from Docker build
# ============================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
env/
.env
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Git
.git/
.gitignore

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Testing
.pytest_cache/
.coverage
htmlcov/
